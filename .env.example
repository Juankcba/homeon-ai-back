# ─── NestJS Backend ─────────────────────────────────────────────────────────
BACKEND_URL=http://127.0.0.1:3005
AI_API_KEY=changeme-ai-secret        # must match AI_API_KEY in backend .env

# ─── Camera overrides (optional – service fetches cameras from backend API) ──
# RTSP_OVERRIDE=rtsp://admin:pass@192.168.1.101:554/stream1,rtsp://...

# ─── Detection tuning ────────────────────────────────────────────────────────
FRAME_INTERVAL=5         # seconds between frame captures per camera
YOLO_CONF=0.45           # YOLO confidence threshold (0–1)
FACE_TOLERANCE=0.55      # face recognition tolerance (lower = stricter)
PLATE_MIN_CONF=0.60      # OCR plate minimum confidence

# ─── Storage ─────────────────────────────────────────────────────────────────
SNAPSHOT_DIR=/snapshots
MAX_SNAPSHOT_DAYS=30

# ─── OCR languages ───────────────────────────────────────────────────────────
OCR_LANGS=es,en
